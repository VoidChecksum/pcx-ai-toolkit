{
  "name": "pcx-ai-toolkit",
  "version": "1.20.0",
  "description": "Source-grounded Enma toolkit for Perception.cx",
  "license": "MIT",
  "homepage": "https://github.com/VoidChecksum/pcx-ai-toolkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VoidChecksum/pcx-ai-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/VoidChecksum/pcx-ai-toolkit/issues"
  },
  "keywords": [
    "perception",
    "enma",
    "pcx",
    "ai-toolkit",
    "game-scripting"
  ],
  "bin": {
    "pcx": "npm/bin/pcx.js"
  },
  "files": [
    "npm/bin/pcx.js",
    "tools/**/*.py",
    "tools/**/*.sh",
    "pcx-bin/pcx-rs*",
    "tools/**/*.ps1",
    "knowledge/*.json",
    "templates/**/*",
    "docs/COUNTS.json",
    "docs/llms.txt",
    "docs/llms-perception-enma.md",
    "README.md",
    "LICENSE",
    "VERSION",
    "knowledge/permission-rules.json",
    "knowledge/deprecated-symbols.json",
    "knowledge/mcp-schema-rules.json",
    "docs/COVERAGE.json",
    "docs/COVERAGE.md",
    "evals/*.json"
  ],
  "scripts": {
    "pack:check": "bun pm pack --dry-run"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
