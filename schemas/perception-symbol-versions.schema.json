{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/VoidChecksum/pcx-ai-toolkit/schemas/perception-symbol-versions.schema.json",
  "title": "Perception Enma symbol version metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "last_verified", "notes", "symbols"],
  "properties": {
    "schema": {"type": "integer", "const": 1},
    "last_verified": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "notes": {"type": "string"},
    "symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "symbol",
          "introduced",
          "first_documented",
          "source",
          "changelog_source",
          "language",
          "api_family",
          "permissions",
          "failure_modes",
          "return_sentinel",
          "requires_context",
          "side_effects",
          "threading",
          "source_anchor",
          "line_start",
          "line_end",
          "kind",
          "signature",
          "return_type",
          "params",
          "deprecated",
          "removed",
          "replacement",
          "notes"
        ],
        "properties": {
          "symbol": {"type": "string", "minLength": 1},
          "introduced": {"type": "string", "pattern": "^(unknown|\\d{4}-\\d{2}-\\d{2}(?:\\([ab]\\))?|<=\\d{4}-\\d{2}-\\d{2}(?:\\([ab]\\))?|\\d{4}-\\d{2}-\\d{2}-or-earlier)$"},
          "first_documented": {"type": "string", "pattern": "^(unknown|\\d{4}-\\d{2}-\\d{2}(?:\\([ab]\\))?|<=\\d{4}-\\d{2}-\\d{2}(?:\\([ab]\\))?|\\d{4}-\\d{2}-\\d{2}-or-earlier)$"},
          "source": {"type": "string", "minLength": 1},
          "changelog_source": {"type": ["string", "null"]},
          "language": {"type": "string", "const": "enma"},
          "api_family": {"type": "string", "minLength": 1},
          "permissions": {"type": "array", "items": {"type": "string"}},
          "failure_modes": {"type": "array", "items": {"type": "string"}},
          "return_sentinel": {"type": ["string", "null"]},
          "requires_context": {"type": ["string", "null"]},
          "side_effects": {"type": "array", "items": {"type": "string"}},
          "threading": {"type": "string", "enum": ["main", "routine", "render", "any", "unknown"]},
          "source_anchor": {"type": ["string", "null"]},
          "line_start": {"type": ["integer", "null"], "minimum": 1},
          "line_end": {"type": ["integer", "null"], "minimum": 1},
          "kind": {"type": "string", "enum": ["function", "method", "type", "constant", "enum", "callback", "page"]},
          "signature": {"type": ["string", "null"]},
          "return_type": {"type": ["string", "null"]},
          "params": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "type"],
              "properties": {
                "name": {"type": "string", "minLength": 1},
                "type": {"type": "string", "minLength": 1}
              }
            }
          },
          "deprecated": {"type": "boolean"},
          "removed": {"type": "boolean"},
          "replacement": {"type": ["string", "null"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
