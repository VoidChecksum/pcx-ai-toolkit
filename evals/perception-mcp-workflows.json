{
  "schema": "pcx-perception-mcp-workflow-evals-v1",
  "cases": [
    {"name": "string xref uses string refs", "task": "find xrefs to PlayerHealth", "workflow": "string_xref", "must_include": ["process/find_string_refs"], "must_not_include": ["process/find_pattern"]},
    {"name": "pattern search bounded", "task": "resolve byte pattern to function", "workflow": "pattern_function", "must_include": ["process/find_all_patterns", "process/find_function_bounds"]},
    {"name": "script validation context first", "task": "validate an Enma script", "workflow": "script_validate", "must_include": ["script/get_context", "script/validate"]},
    {"name": "pointer chain validates leaf", "task": "validate pointer chain", "workflow": "pointer_chain", "must_include": ["process/read_pointer_chain", "process/is_valid_address"]},
    {"name": "permission denied stops write", "task": "patch safe write bytes", "workflow": "patch_safe_write", "must_warn": ["explicit write_memory permission"]},
    {"name": "module inventory maps modules", "task": "module inventory", "workflow": "module_inventory", "must_include": ["process/get_module_list"]},
    {"name": "rtti analysis uses vtable and rtti", "task": "rtti class analysis", "workflow": "rtti_class_analysis", "must_include": ["process/analyze_vtable", "process/read_rtti"]},
    {"name": "capability fallback warns", "task": "find string refs", "workflow": "string_xref", "capabilities": ["process/reference_by_name", "process/get_module_by_name", "process/dereference"], "must_warn": ["fallback"]}
  ]
}
