{
  "schema": "pcx-hallucination-regression-v2",
  "description": "Golden cases for adversarial Enma hallucination regression with expected finding codes.",
  "cases": [
    {
      "name": "enma-clean-minimal-main",
      "mode": "code",
      "language": "enma",
      "should_pass": true,
      "input": "int64 main() {\n    println(\"hello\");\n    return 1;\n}\n",
      "expected_findings": []
    },
    {
      "name": "answer-fence-clean-enma",
      "mode": "answer",
      "language": "enma",
      "should_pass": true,
      "input": "```enma\nint64 main() {\n    println(\"hello\");\n    return 1;\n}\n```",
      "expected_findings": []
    },
    {
      "name": "enma-rejects-lifecycle-void-main",
      "mode": "code",
      "language": "enma",
      "should_pass": false,
      "input": "void main(){ println(\"x\"); }",
      "expected_findings": [
        {
          "code": "invalid_entrypoint",
          "symbol": "main",
          "severity": "error"
        }
      ]
    },
    {
      "name": "enma-rejects-lifecycle-return-true",
      "mode": "code",
      "language": "enma",
      "should_pass": false,
      "input": "int64 main(){ return true; }",
      "expected_findings": [
        {
          "code": "invalid_entrypoint_return",
          "symbol": "return true",
          "severity": "error"
        }
      ]
    },
    {
      "name": "enma-rejects-lifecycle-register-callback",
      "mode": "code",
      "language": "enma",
      "should_pass": false,
      "input": "int64 main(){ register_callback(on_render, 0); return 1; }",
      "expected_findings": [
        {
          "code": "wrong_routine_api",
          "symbol": "register_callback",
          "severity": "error"
        }
      ]
    },
    {
      "name": "enma-rejects-lifecycle-routine-missing-cast",
      "mode": "code",
      "language": "enma",
      "should_pass": false,
      "input": "void r(int64 d){} int64 main(){ register_routine(r,0); return 1; }",
      "expected_findings": [
        {
          "code": "routine_missing_cast",
          "symbol": "register_routine",
          "severity": "error"
        }
      ]
    },
    {
